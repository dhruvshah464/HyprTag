{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User identity, gamification stats, and preferences",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "isElite": { "type": "boolean" },
        "onboarded": { "type": "boolean" },
        "niche": { "type": "string" },
        "identity": {
          "type": "object",
          "properties": {
            "label": { "type": "string" },
            "score": { "type": "integer" },
            "archetype": { "type": "string" }
          }
        },
        "streak": { "type": "integer" },
        "level": { "type": "integer" },
        "points": { "type": "integer" },
        "potentialIncome": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "isElite"]
    },
    "Content": {
      "title": "Generated Content",
      "description": "A piece of generated viral content (hooks, etc)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "hook": { "type": "string" },
        "caption": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "viralScore": { "type": "integer" },
        "type": { "type": "string", "enum": ["hook", "reel", "post"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt"]
    },
    "Post": {
      "title": "Social Post",
      "description": "A scheduled or published social media post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "contentId": { "type": "string" },
        "platform": { "type": "string" },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "published"] },
        "reach": { "type": "integer" },
        "likes": { "type": "integer" },
        "comments": { "type": "integer" },
        "shares": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "GrowthInsight": {
      "title": "Growth Insight",
      "description": "Neural feedback on post performance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "status": { "type": "string", "enum": ["up", "down", "neutral"] },
        "metric": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Challenge": {
      "title": "Viral Challenge",
      "description": "Daily challenges for users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "points": { "type": "integer" },
        "icon": { "type": "string" }
      }
    },
    "Earnings": {
      "title": "Earning Progress",
      "description": "User progress in the monetization journey",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currentStage": { "type": "integer" },
        "followerTarget": { "type": "integer" },
        "estimatedMonthly": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": {
       "schema": "User",
       "description": "Registered user profiles and settings"
    },
    "content": {
      "schema": "Content",
      "description": "Library of AI generated hooks and captions"
    },
    "posts": {
      "schema": "Post",
      "description": "Schedule of past and future posts"
    },
    "insights": {
      "schema": "GrowthInsight",
      "description": "AI feedback on user growth"
    },
    "challenges": {
      "schema": "Challenge",
      "description": "Daily creator challenges"
    },
    "earnings": {
      "schema": "Earnings",
      "description": "Monetization tracking"
    }
  }
}
