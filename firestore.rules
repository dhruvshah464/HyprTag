rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == "464dhruvshah@gmail.com"; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9.\\-_]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    
    function isValidGeneration(data) {
      return data.userId == request.auth.uid 
        && (data.get('content', '') is string && data.get('content', '').size() <= 10000)
        && (data.get('type', 'image') in ['image', 'video', 'analysis'])
        && (data.get('videoUrl', null) is string || data.get('videoUrl', null) == null)
        && (data.get('result', null) is map || data.get('result', null) == null)
        && (data.get('metadata', null) is map || data.get('metadata', null) == null)
        && (data.get('reach', 0) is int)
        && (data.get('likes', 0) is int)
        && (data.get('comments', 0) is int)
        && data.createdAt == request.time;
    }

    function isValidScheduledPost(data) {
      return data.userId == request.auth.uid
        && (data.get('content', '') is string && data.get('content', '').size() <= 5000)
        && (data.get('hashtags', []) is list)
        && (data.get('platforms', []) is list)
        && (data.get('scheduledTime', null) is string || data.get('scheduledTime', null) == null)
        && (data.get('notes', null) is string || data.get('notes', null) == null)
        && (data.get('status', 'idea') in ['idea', 'draft', 'scheduled', 'published', 'pending'])
        && data.createdAt == request.time;
    }

    function isValidCompetitorInsight(data) {
      return data.userId == request.auth.uid
        && data.profileUrl is string && data.profileUrl.size() <= 1024
        && data.insight is string && data.insight.size() <= 10000
        && data.trendingTags is list
        && data.createdAt == request.time;
    }

    function isValidUser(data) {
      return (data.get('email', null) is string || data.get('email', null) == null)
        && (data.get('isElite', false) is bool)
        && (data.get('onboarded', false) is bool)
        && (data.get('demoCompleted', false) is bool)
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
        && (data.get('niche', '') is string && data.get('niche', '').size() <= 100)
        && (data.get('goals', []) is list)
        && (data.get('connections', {}) is map)
        && (data.get('socialHandles', {}) is map)
        && (data.get('linkedPlatforms', []) is list)
        && (data.get('createdAt', request.time) <= request.time);
    }

    function isValidPrivateData(data) {
      return (data.get('tokens', {}) is map)
        && (data.get('keys', {}) is map)
        && (data.get('updatedAt', request.time) == request.time);
    }

    // --- Collection Routes ---
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Strictly block user listing
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming())
                       && incoming().isElite == false;
      allow update: if (isOwner(userId) || isAdmin()) && isValidId(userId) && isValidUser(incoming())
                       && (isAdmin() || incoming().isElite == existing().isElite);
      allow delete: if isAdmin();

      // Isolated Private Collection for sensitive credentials
      match /private/{docId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if false; // Never list sensitive keys/tokens
        allow write: if (isOwner(userId) || isAdmin()) && isValidId(docId) && isValidPrivateData(incoming());
      }
    }

    match /generations/{genId} {
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidId(genId) && isValidGeneration(incoming());
      allow update: if (isOwner(existing().userId) || isAdmin()) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /scheduledPosts/{postId} {
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidId(postId) && isValidScheduledPost(incoming());
      allow update: if (isOwner(existing().userId) || isAdmin()) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /competitorInsights/{insightId} {
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidId(insightId) && isValidCompetitorInsight(incoming());
      allow delete: if isOwner(existing().userId) || isAdmin();
    }
  }
}
