rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default deny is implicit.
    // We only need to define what IS allowed.

    // 2. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    incoming().email == request.auth.token.email &&
                    incoming().keys().hasAll(['email', 'isElite']);
      allow update: if isSignedIn() && request.auth.uid == userId && 
                    incoming().email == existing().email &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'displayName', 'niche', 'identity', 'streak', 'level', 'points', 
                      'potentialIncome', 'onboarded', 'lastActionAt', 'connections', 
                      'socialHandles', 'linkedPlatforms', 'demoCompleted'
                    ]);
    }

    // 3. Content Collection (AI Generations)
    match /content/{contentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isVerified() && 
                    incoming().userId == request.auth.uid;
    }

    // 4. Posts Collection (Planner)
    match /posts/{postId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isVerified() && 
                    incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid &&
                    incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 5. Growth Insights
    match /insights/{insightId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 6. Competitor Insights
    match /competitorInsights/{insightId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isVerified() && 
                    incoming().userId == request.auth.uid;
    }

    // 7. Challenges (Global)
    match /challenges/{challengeId} {
      allow read: if isSignedIn();
    }

    // 8. Earnings (Monetization)
    match /earnings/{earningId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && isVerified() && 
                             (incoming().userId == request.auth.uid || (resource != null && resource.data.userId == request.auth.uid));
    }
  }
}
