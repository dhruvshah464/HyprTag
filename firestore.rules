rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    
    function isValidGeneration(data) {
      return data.userId == request.auth.uid 
        && data.content is string
        && data.result is map
        && (data.reach is int || data.reach == null)
        && (data.likes is int || data.likes == null)
        && (data.comments is int || data.comments == null)
        && data.createdAt == request.time;
    }

    function isValidScheduledPost(data) {
      return data.userId == request.auth.uid
        && (data.content is string || data.content == null)
        && data.hashtags is list
        && (data.platforms is list || data.platforms == null)
        && (data.scheduledTime is string || data.scheduledTime == null)
        && data.status in ['idea', 'draft', 'scheduled', 'published', 'pending']
        && data.createdAt == request.time;
    }

    function isValidCompetitorInsight(data) {
      return data.userId == request.auth.uid
        && data.profileUrl is string
        && data.insight is string
        && data.trendingTags is list
        && data.createdAt == request.time;
    }

    function isValidUser(data) {
      return (data.email is string || data.email == null)
        && (data.isElite is bool || data.isElite == null)
        && (data.onboarded is bool || data.onboarded == null)
        && (data.displayName is string || data.displayName == null)
        && (data.niche is string || data.niche == null)
        && (data.goals is list || data.goals == null)
        && (data.connections is map || data.connections == null)
        && (data.socialHandles is map || data.socialHandles == null)
        && (data.createdAt is string || data.createdAt == null)
        && (data.updatedAt != null || true);
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId 
                    && isValidUser(incoming())
                    && (
                      // Action: Upgrade to Elite
                      incoming().diff(existing()).affectedKeys().hasAny(['isElite', 'updatedAt']) ||
                      // Action: Complete Onboarding
                      incoming().diff(existing()).affectedKeys().hasAny(['onboarded', 'displayName', 'niche', 'goals', 'connections', 'socialHandles', 'updatedAt'])
                    );
    }

    match /generations/{genId} {
      allow get: if isSignedIn() && isValidId(genId) && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(genId) && isValidGeneration(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidId(genId) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt;
      allow delete: if isVerified() && isOwner(existing().userId) && isValidId(genId);
    }

    match /scheduledPosts/{postId} {
      allow get: if isSignedIn() && isValidId(postId) && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(postId) && isValidScheduledPost(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidId(postId)
                    && incoming().userId == existing().userId 
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isVerified() && isOwner(existing().userId) && isValidId(postId);
    }

    match /competitorInsights/{insightId} {
      allow get: if isSignedIn() && isValidId(insightId) && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isVerified() && isValidId(insightId) && isValidCompetitorInsight(incoming());
      allow delete: if isVerified() && isOwner(existing().userId) && isValidId(insightId);
    }
  }
}
